generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  message      String?
  interestedIn String?
  source       String   @default("website")
  createdAt    DateTime @default(now())
}
